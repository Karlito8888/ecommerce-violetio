# Supabase Local Development
# Copy this file to .env.local and fill in the values from `supabase start` output
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=<your-anon-key-from-supabase-start>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key-from-supabase-start>

# Run `supabase start` to get the actual keys.
# "Publishable" key = SUPABASE_ANON_KEY, "Secret" key = SUPABASE_SERVICE_ROLE_KEY

# OpenAI — Used by Edge Functions for AI search embeddings (text-embedding-3-small)
OPENAI_API_KEY=<your-openai-api-key>

# Stripe — Required for mobile Stripe integration (Expo app uses EXPO_PUBLIC_ prefix)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
