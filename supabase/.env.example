# Violet API — Commerce authentication for Edge Functions
VIOLET_APP_ID=your_violet_app_id
VIOLET_APP_SECRET=your_violet_app_secret
VIOLET_USERNAME=your_violet_account_email
VIOLET_PASSWORD=your_violet_account_password
VIOLET_API_BASE=https://sandbox-api.violet.io/v1

# OpenAI — Used by generate-embeddings and search-products Edge Functions
OPENAI_API_KEY=sk-your_openai_key

# Email notifications — Used by send-notification Edge Function (Story 5.6)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
APP_URL=http://localhost:3000
