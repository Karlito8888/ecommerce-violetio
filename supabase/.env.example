# =============================================================================
# Supabase Edge Functions — Environment Variables
# =============================================================================
# Only variables needed by Deno Edge Functions.
# Copy to .env: cp .env.example .env
#
# In production: use `supabase secrets set KEY=value` instead of files.
# Supabase auto-injects SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY.
# =============================================================================

# ─── Violet.io ───────────────────────────────────────────────────────────────
VIOLET_APP_ID=your_violet_app_id
VIOLET_APP_SECRET=your_violet_app_secret
VIOLET_USERNAME=your_violet_account_email
VIOLET_PASSWORD=your_violet_account_password
VIOLET_API_BASE=https://sandbox-api.violet.io/v1

# ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_key

# ─── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_key
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
APP_URL=http://localhost:3000
SUPPORT_EMAIL=support@yourdomain.com

# ─── Health Monitoring ───────────────────────────────────────────────────────
HEALTH_CHECK_SECRET=your_random_secret
