<?xml version="1.0" encoding="UTF-8"?>
<!--
  Sitemap for Maison Émile (Story 3.8 — SEO Foundation).

  STATIC PAGES ONLY — Product URLs require dynamic generation.

  Why static?
  TanStack Start v1.166.2 does not expose `createServerFileRoute` for custom
  API routes (XML responses). Product URLs must be generated via the build
  script: `bun run generate:sitemap` (see scripts/generate-sitemap.ts).

  Run `bun run generate:sitemap` to regenerate this file with product URLs
  from the Supabase `product_embeddings` table (available=true).

  Story 7.4 (Sitemap & Indexing) will implement a fully dynamic server-side
  sitemap once TanStack Start supports API routes.

  @see scripts/generate-sitemap.ts — dynamic generation script
  @see robots.txt — Sitemap directive points here
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://www.maisonemile.com/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://www.maisonemile.com/products</loc>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://www.maisonemile.com/about</loc>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
  <!-- Product URLs are added by scripts/generate-sitemap.ts -->
</urlset>
