<?xml version="1.0" encoding="UTF-8"?>
<!--
  Sitemap for Maison Émile

  IMPORTANT: This is a static fallback. Run `bun run generate:sitemap` to
  regenerate with dynamic product and content URLs from Supabase.
  The generate script queries product_embeddings and content_pages tables
  and produces a complete sitemap. Run it:
  - After product sync (webhook processing)
  - After content publish/update
  - Before deployment (add to CI/CD pipeline)

  @see scripts/generate-sitemap.ts — dynamic generation script
  @see robots.txt — Sitemap directive points here
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://www.maisonemile.com/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>https://www.maisonemile.com/products</loc>
    <changefreq>daily</changefreq>
    <priority>0.9</priority>
  </url>
  <url>
    <loc>https://www.maisonemile.com/content</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>https://www.maisonemile.com/about</loc>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
  <!-- Product and content page URLs are added by scripts/generate-sitemap.ts -->
</urlset>
