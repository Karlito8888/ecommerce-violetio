# Violet API — Commerce authentication (server-side only)
VIOLET_APP_ID=your_violet_app_id
VIOLET_APP_SECRET=your_violet_app_secret
VIOLET_USERNAME=your_violet_account_email
VIOLET_PASSWORD=your_violet_account_password
VIOLET_API_BASE=https://sandbox-api.violet.io/v1

# Stripe — publishable key (safe for client, VITE_ prefix exposes to browser)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Supabase — server-side (used by TanStack Start server functions)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase — client-side (VITE_ prefix exposes to browser)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
