# =============================================================================
# Maison Emile — Environment Variables
# =============================================================================
# Single source of truth for ALL environment variables.
# Copy to .env.local and fill in your values: cp .env.example .env.local
#
# In production, these are injected by the hosting platform (not via files).
# =============================================================================

# ─── Convex (Self-Hosted) ──────────────────────────────────────────────────
# Convex backend — binaire Rust, pas de cloud, pas de Docker.
# En dev : npx convex dev --local configure automatiquement CONVEX_URL.
# En prod : binaire Rust + systemd + Caddy (voir MIGRATION-SUPABASE-TO-CONVEX.md §4)

# Auto-configurés par npx convex dev --local (ne pas modifier manuellement)
# CONVEX_DEPLOYMENT=anonymous:anonymous-E-commerce
# CONVEX_URL=http://127.0.0.1:3210
# CONVEX_SITE_URL=http://127.0.0.1:3211

# Client-side web (VITE_ prefix required by Vite)
# VITE_CONVEX_URL=http://127.0.0.1:3210

# Mobile (EXPO_PUBLIC_ prefix required by Expo)
# EXPO_PUBLIC_CONVEX_URL=http://10.0.2.2:3210  # Android emulator
# EXPO_PUBLIC_CONVEX_URL=http://127.0.0.1:3210  # iOS

# ─── Supabase (LÉGACY — à supprimer après migration) ─────────────────────
# ⚠️ Ces variables seront supprimées une fois la migration Convex terminée.
# Ne pas supprimer tant que le code Supabase n'a pas été entièrement remplacé.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Violet.io (Commerce API) ───────────────────────────────────────────────
# Server-side only — NEVER expose to client
VIOLET_APP_ID=your_violet_app_id
VIOLET_APP_SECRET=your_violet_app_secret
VIOLET_USERNAME=your_violet_account_email
VIOLET_PASSWORD=your_violet_account_password
VIOLET_API_BASE=https://sandbox-api.violet.io/v1

# ─── Stripe (Payments) ──────────────────────────────────────────────────────
# Client-side (browser + mobile)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
# Stripe Platform account country. Determines which merchants can be onboarded.
# Sandbox: US (Violet demo merchants are US-based Shopify stores)
# Production: FR (or your actual EEA country — EU platform = EEA merchants only)
# @see https://docs.violet.io/prism/payments/payment-settings/supported-countries
VITE_STRIPE_ACCOUNT_COUNTRY=US
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
EXPO_PUBLIC_STRIPE_ACCOUNT_COUNTRY=US
EXPO_PUBLIC_APPLE_MERCHANT_ID=merchant.your.id
EXPO_PUBLIC_API_URL=http://127.0.0.1:3000

# Server-side only (Server Functions + Edge Functions)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Server-side only (Convex Actions)
RESEND_API_KEY=re_your_resend_key
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
APP_URL=http://localhost:3000
SUPPORT_EMAIL=support@yourdomain.com

# ─── Convex Auth ─────────────────────────────────────────────────────────────
# Resend key for email verification + password reset OTPs.
# Configured via: npx convex env set AUTH_RESEND_KEY <key>
AUTH_RESEND_KEY=re_your_resend_key

# Sign in with Apple (requires Apple Developer account)
# Configured via: npx convex env set AUTH_APPLE_ID <service-id>
#                 npx convex env set AUTH_APPLE_SECRET <jwt-secret>
# AUTH_APPLE_ID=com.yourapp.signin
# AUTH_APPLE_SECRET=your_apple_jwt_secret

# Sign in with Google (requires Google Cloud project)
# Configured via: npx convex env set AUTH_GOOGLE_ID <client-id>
#                 npx convex env set AUTH_GOOGLE_SECRET <client-secret>
# AUTH_GOOGLE_ID=your_google_client_id
# AUTH_GOOGLE_SECRET=your_google_client_secret

# ─── Health Monitoring ───────────────────────────────────────────────────────
# Server-side only (Convex HTTP Actions)
HEALTH_CHECK_SECRET=your_random_secret

# ─── Webhooks ───────────────────────────────────────────────────────────────
# Shared secret for HMAC validation of incoming Violet webhooks.
# Configured via: npx convex env set WEBHOOK_SECRET <value>
WEBHOOK_SECRET=your_internal_webhook_secret
