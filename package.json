{
  "name": "ecommerce-monorepo",
  "private": true,
  "packageManager": "bun@1.2.4",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --env-file=.env.local --cwd=apps/web run dev",
    "dev:mobile": "bun --cwd=apps/mobile run start",
    "dev:functions": "supabase functions serve --env-file supabase/.env",
    "build": "bun --env-file=.env.local --cwd=apps/web run build",
    "typecheck": "bun --cwd=apps/web run typecheck && bun --cwd=apps/mobile run typecheck",
    "lint": "eslint apps/ packages/ --max-warnings 0",
    "lint:fix": "eslint apps/ packages/ --fix",
    "format": "prettier --check \"apps/**/*.{ts,tsx,css}\" \"packages/**/*.{ts,tsx}\"",
    "format:fix": "prettier --write \"apps/**/*.{ts,tsx,css}\" \"packages/**/*.{ts,tsx}\"",
    "test": "bun --cwd=apps/web run test && bun --cwd=packages/shared run test",
    "fix-all": "bun run format:fix && bun run lint:fix && bun run typecheck",
    "generate:sitemap": "bun run scripts/generate-sitemap.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript-eslint": "^8.56.1"
  }
}
