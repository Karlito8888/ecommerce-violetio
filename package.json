{
  "name": "ecommerce-monorepo",
  "private": true,
  "packageManager": "bun@1.3.14",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --env-file=.env.local --cwd=apps/web run dev",
    "dev:mobile": "bun --cwd=apps/mobile run start",
    "dev:android": "bun --cwd=apps/mobile run android",
    "build": "bun --env-file=.env.local --cwd=apps/web run build",
    "typecheck": "bun --cwd=apps/web run typecheck && bun --cwd=apps/mobile run typecheck",
    "lint": "eslint apps/ packages/ convex/ --max-warnings 0",
    "lint:fix": "eslint apps/ packages/ convex/ --fix",
    "format": "prettier --check \"apps/**/*.{ts,tsx,css}\" \"packages/**/*.{ts,tsx}\" \"convex/**/*.ts\"",
    "format:fix": "prettier --write \"apps/**/*.{ts,tsx,css}\" \"packages/**/*.{ts,tsx}\" \"convex/**/*.ts\"",
    "test": "bun --cwd=apps/web run test && bun --cwd=packages/shared run test && bun --cwd=apps/mobile run test && npx vitest run --root convex",
    "check": "bun run format && bun run lint && bun run typecheck && bun run test && bun run build",
    "fix-all": "bun run format:fix && bun run lint:fix && bun run typecheck",
    "generate:sitemap": "bun run scripts/generate-sitemap.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "convex-test": "^0.0.53",
    "eslint": "^10.2.1",
    "prettier": "^3.8.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "@types/react": "^19.2.14"
  },
  "dependencies": {
    "@auth/core": "^0.37.0",
    "@convex-dev/auth": "^0.0.92",
    "@oslojs/crypto": "^1.0.1",
    "convex": "^1.39.1",
    "resend": "^6.12.3",
    "zod": "^4.4.3"
  }
}
